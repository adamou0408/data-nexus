# Dev container for authz-api.
# Bind-mounts source from host; node_modules lives in an anonymous volume
# so host's node_modules (which may be Windows-built) doesn't shadow the
# Linux ones installed here.
FROM node:22-bookworm-slim

WORKDIR /app

# Tools occasionally needed by native deps (pg, oracledb thin mode is fine
# without instant client; keep build-essential out unless we hit a build).
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV CHOKIDAR_USEPOLLING=true \
    CHOKIDAR_INTERVAL=400 \
    NODE_ENV=development

EXPOSE 13001

CMD ["npm", "run", "dev"]
