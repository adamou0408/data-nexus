# ============================================================
# Phison Data Nexus — Environment Variables Template (SEC-06b)
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Defaults shown match docker-compose dev setup; production deploys
# MUST override every "REQUIRED in production" line.
#
# Generate ENCRYPTION_KEY with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# -----------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------
NODE_ENV=development          # set to "production" in prod; triggers strict env validation

# -----------------------------------------------------------
# AuthZ API (services/authz-api)
# -----------------------------------------------------------
PORT=13001
DB_HOST=localhost
DB_PORT=15432
DB_NAME=nexus_authz
DB_USER=nexus_admin
DB_PASSWORD=                  # REQUIRED in production
ENCRYPTION_KEY=               # REQUIRED in production — 64-char hex (AES-256-GCM)

# JWT/OIDC (optional — leave unset for dev X-User-Id header mode)
# JWT_ISSUER=https://keycloak.example.com/realms/nexus
# JWT_AUDIENCE=authz-api
# JWT_JWKS_URI=https://keycloak.example.com/realms/nexus/protocol/openid-connect/certs

# -----------------------------------------------------------
# Identity Sync (services/identity-sync)
# -----------------------------------------------------------
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=phison,dc=com
LDAP_BIND_PASSWORD=           # REQUIRED in production
LDAP_BASE_DN=dc=phison,dc=com
LDAP_GROUPS_OU=ou=groups,dc=phison,dc=com
LDAP_PEOPLE_OU=ou=people,dc=phison,dc=com

PG_HOST=localhost
PG_PORT=15432
PG_DATABASE=nexus_authz
PG_USER=nexus_admin
PG_PASSWORD=                  # REQUIRED in production

# -----------------------------------------------------------
# Dashboard (apps/authz-dashboard) — Vite reads VITE_* only
# -----------------------------------------------------------
VITE_API_BASE_URL=http://localhost:13001
