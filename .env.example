# ============================================================
# Phison Data Nexus — Environment Variables Template (SEC-06b)
#
# THIS FILE IS A TEMPLATE — committed to git, contains NO real values.
# Copy to `.env` (gitignored) and fill in your environment's values.
#
#   cp .env.example .env
#
# Loading mechanism:
#   - services/authz-api: tsx --env-file-if-exists=../../.env (Node 22+ native)
#   - apps/authz-dashboard: Vite reads VITE_* from apps/authz-dashboard/.env.local
#   - identity-sync: same as authz-api (root .env via tsx flag)
#
# Tags used below:
#   [REQUIRED]              must be set for the service to start
#   [REQUIRED in production] dev fallback exists, prod start fails without it
#   [OPTIONAL]              feature toggle — leave blank to disable
#   [LOCAL DEV DEFAULT]     value shown is the docker-compose dev default
# ============================================================

# -----------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------
NODE_ENV=development          # development | production. Production triggers strict env validation.

# -----------------------------------------------------------
# AuthZ API — services/authz-api (port 13001)
# -----------------------------------------------------------
PORT=13001
DB_HOST=localhost             # [LOCAL DEV DEFAULT] docker-compose exposes PG on host
DB_PORT=15432                 # [LOCAL DEV DEFAULT] non-standard to avoid colliding with system PG
DB_NAME=nexus_authz
DB_USER=nexus_admin
DB_PASSWORD=                  # [REQUIRED in production] dev falls back to 'nexus_dev_password'
ENCRYPTION_KEY=               # [REQUIRED in production] 64-char hex (AES-256-GCM).
                              # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# -- JWT / OIDC (Keycloak SSO) -------------------------------
# [OPTIONAL] When all three set, authz-api validates Bearer tokens via JWKS (RS256).
# Unset = dev mode using X-User-Id header. Both modes coexist when set
# (X-User-Id fallback remains active for smoke scripts).
# See docs/keycloak-setup.md for the realm scaffolding created 2026-04-29.
JWT_ISSUER=                   # e.g. http://<keycloak-host>:8080/realms/<realm>
JWT_AUDIENCE=                 # e.g. authz-api  (must match the audience-mapper on the SPA client)
JWT_JWKS_URI=                 # e.g. http://<keycloak-host>:8080/realms/<realm>/protocol/openid-connect/certs

# -----------------------------------------------------------
# Identity Sync — services/identity-sync
# -----------------------------------------------------------
LDAP_URL=ldap://localhost:389         # [LOCAL DEV DEFAULT] docker-compose OpenLDAP
LDAP_BIND_DN=cn=admin,dc=phison,dc=com
LDAP_BIND_PASSWORD=                   # [REQUIRED in production] dev OpenLDAP uses 'nexus_ldap_dev'
LDAP_BASE_DN=dc=phison,dc=com
LDAP_GROUPS_OU=ou=groups,dc=phison,dc=com
LDAP_PEOPLE_OU=ou=people,dc=phison,dc=com

PG_HOST=localhost
PG_PORT=15432
PG_DATABASE=nexus_authz
PG_USER=nexus_admin
PG_PASSWORD=                  # [REQUIRED in production] same dev fallback as DB_PASSWORD

# -----------------------------------------------------------
# Path C — ds:pg_k8 (real Phison Greenplum, schema tiptop)
# Bootstrapped by database/seed/dev-seed.sql with NULL password.
# Set this and re-run `make db-reset` (or update via dashboard) to
# enable Path C demos and Data Explorer browse on tiptop.
# -----------------------------------------------------------
PG_K8_PASSWORD=               # [OPTIONAL in dev / REQUIRED to demo Path C] gpadmin password for 192.168.199.72:30000/dc

# -----------------------------------------------------------
# Dashboard — apps/authz-dashboard (port 13173)
# Vite reads VITE_* only. Place these in apps/authz-dashboard/.env.local
# (NOT in this root .env — Vite scopes its env to the app's CWD).
# -----------------------------------------------------------
VITE_API_BASE_URL=http://localhost:13001

# -- Keycloak SSO (frontend) ---------------------------------
# [OPTIONAL] When set, the dashboard renders a Keycloak login button and
# forwards Bearer tokens to authz-api. Backend JWT_* must also be set.
VITE_KEYCLOAK_URL=            # e.g. http://<keycloak-host>:8080
VITE_KEYCLOAK_REALM=          # e.g. data-nexus
VITE_KEYCLOAK_CLIENT_ID=      # e.g. authz-dashboard
